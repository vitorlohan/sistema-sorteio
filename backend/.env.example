# Servidor
NODE_ENV=development
PORT=3000

# MongoDB - Coloque o endereço do seu banco MongoDB aqui
MONGODB_URI=mongodb://localhost:27017/sistema-sorteio

# JWT
JWT_SECRET=ALTERE_PARA_UMA_CHAVE_SECRETA_FORTE_AQUI
JWT_REFRESH_SECRET=ALTERE_PARA_OUTRA_CHAVE_SECRETA_FORTE_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# HTTP/2 (coloque o caminho dos certificados SSL para produção)
SSL_KEY_PATH=
SSL_CERT_PATH=
